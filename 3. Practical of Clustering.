# Step 1: Load Required Library
library(ggplot2)

# Step 2: Generate Sample Data with Clear Clusters
set.seed(123)

cluster1 <- data.frame(
  X = rnorm(20, mean = 5, sd = 0.8),
  Y = rnorm(20, mean = 5, sd = 0.8)
)

cluster2 <- data.frame(
  X = rnorm(20, mean = 15, sd = 0.8),
  Y = rnorm(20, mean = 15, sd = 0.8)
)

cluster3 <- data.frame(
  X = rnorm(20, mean = 25, sd = 0.8),
  Y = rnorm(20, mean = 5, sd = 0.8)
)

data <- rbind(cluster1, cluster2, cluster3)

# Step 3: Apply K-Means Clustering
kmeans_result <- kmeans(data, centers = 3)

# Step 4: Add Cluster Labels to Data
data$Cluster <- as.factor(kmeans_result$cluster)

# Step 5: Plot the Clusters
ggplot(data, aes(x = X, y = Y, color = Cluster)) +
  geom_point(size = 3) +
  labs(title = "K-Means Clustering with Generated Dataset",
       x = "Feature X",
       y = "Feature Y") +
  theme_minimal()

